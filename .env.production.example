# Production settings for vyapto.developmentalphawizz.com
# Copy these values into your server .env file

APP_ENV=production
APP_DEBUG=false
APP_URL=https://vyapto.developmentalphawizz.com

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true
SESSION_PATH=/

# Use file cache on shared hosting if database cache causes issues
# CACHE_STORE=file
