# Production settings for vyapto.developmentalphawizz.com
# Copy these into the SERVER .env (not only local), then clear config cache.

APP_ENV=production
APP_DEBUG=false
APP_URL=https://vyapto.developmentalphawizz.com

# IMPORTANT: wrong SESSION_* values cause 419 Page Expired and login loops
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_SAME_SITE=lax

CACHE_STORE=file

# After saving .env on the server, run:
# php artisan config:clear
# php artisan cache:clear
# php artisan view:clear
# php artisan optimize:clear
#
# Also ensure storage is writable (if using SESSION_DRIVER=file):
# chmod -R 775 storage bootstrap/cache
