# Production settings for vyapto.developmentalphawizz.com
# Copy these values into your server .env file

APP_ENV=production
APP_DEBUG=false
APP_URL=https://vyapto.developmentalphawizz.com

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_SAME_SITE=lax

CACHE_STORE=file

# After updating .env on the server, run:
# php artisan config:clear
# php artisan cache:clear
# php artisan view:clear
# chmod -R 775 storage bootstrap/cache
